#!/bin/bash

mkdir -p /var/apps/edge/shares/data/config
mkdir -p /var/apps/edge/shares/downloads

# Stale Wayland/XDG sockets from previous development installs can make the
# Selkies desktop loop forever before WebSocket becomes usable.
rm -rf /var/apps/edge/shares/data/config/.XDG
rm -rf /var/apps/edge/shares/data/config/.cache/labwc
rm -f /var/apps/edge/shares/data/config/.Xauthority
rm -f /var/apps/edge/shares/data/config/start-edge.sh
rm -f /var/apps/edge/shares/data/config/edge-autolaunch.sh
rm -f /var/apps/edge/shares/data/config/edge-autolaunch.log
rm -f /var/apps/edge/shares/data/config/edge-autolaunch-daemon.log
rm -f /var/apps/edge/shares/data/config/.config/labwc/autostart
rm -f /var/apps/edge/shares/data/config/.config/openbox/autostart

exit 0

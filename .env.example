# Use latest for browser updates. Pin a version here if you need repeatability.
EDGE_IMAGE=lscr.io/linuxserver/msedge:latest

# Host HTTPS port. Open https://NAS_IP:3443 after startup.
EDGE_HTTPS_PORT=3443

# Replace both values before starting the container.
EDGE_USERNAME=edge
EDGE_PASSWORD=change-me-before-start

# Match the owner of ./data on the NAS. Run: id
PUID=1000
PGID=1000

TZ=Asia/Shanghai
EDGE_LOCALE=zh_CN.UTF-8
EDGE_TITLE=Edge Browser

# AMD Radeon 780M is normally /dev/dri/renderD128.
DRI_RENDER_NODE=/dev/dri/renderD128

# Limit the remote display instead of using the image's 16K default.
MAX_RES=3840x2160
